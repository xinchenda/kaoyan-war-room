{
  "name": "kaoyan-war-room",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/sync-public-dashboard.mjs && WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "node scripts/sync-public-dashboard.mjs && WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "build:pages": "node scripts/build-pages.mjs",
    "sync:intel": "node scripts/sync-intel.mjs",
    "check:feed": "node scripts/check-feed.mjs",
    "check:site": "node scripts/check-site.mjs",
    "test": "node --check app.js && node --check sw.js && node --test tests/*.test.mjs"
  },
  "dependencies": {
    "cheerio": "1.1.2",
    "next": "16.2.11",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.46.0",
    "@types/node": "22.19.19",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-rsc": "0.5.27",
    "react-server-dom-webpack": "19.2.7",
    "typescript": "5.9.3",
    "vinext": "0.2.1",
    "vite": "8.1.5",
    "wrangler": "4.113.0"
  },
  "overrides": {
    "fast-uri": "4.1.1",
    "postcss": "8.5.19",
    "sharp": "0.35.3"
  }
}
