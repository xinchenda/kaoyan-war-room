{
  "name": "kaoyan-war-room",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/sync-public-dashboard.mjs && WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "node scripts/sync-public-dashboard.mjs && WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "build:pages": "node scripts/build-pages.mjs",
    "sync:intel": "node scripts/sync-intel.mjs",
    "test": "node --check app.js && node --test tests/*.test.mjs"
  },
  "dependencies": {
    "cheerio": "1.1.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "react-server-dom-webpack": "19.2.6",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  }
}
